{
  "name": "hearth",
  "version": "0.1.0",
  "private": true,
  "description": "Hearth — a browser TUI for managing tmux sessions across servers",
  "packageManager": "bun@1.3.6",
  "workspaces": [
    "apps/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "bun run --filter '*' dev",
    "build": "bun run --filter '*' build",
    "typecheck": "bun run --filter '*' typecheck",
    "dev:web": "bun run --filter '@hearth/web' dev",
    "dev:hub": "bun run --filter '@hearth/hub' dev"
  }
}
