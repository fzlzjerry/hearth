{
  "name": "@hearth/hub",
  "version": "0.1.0",
  "private": true,
  "description": "hearthd — the Hearth terminal daemon (Fastify + ssh2/node-pty <-> tmux)",
  "type": "module",
  "bin": {
    "hearthd": "dist/index.js"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/websocket": "^11.2.0",
    "dotenv": "^16.4.7",
    "fastify": "^5.8.5",
    "jsonwebtoken": "^9.0.2",
    "pino": "^9.5.0",
    "ssh2": "^1.17.0",
    "zod": "^3.24.1"
  },
  "optionalDependencies": {
    "node-pty": "^1.1.0"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.5",
    "@types/ssh2": "^1.15.1",
    "@types/ws": "^8.5.13",
    "pino-pretty": "^13.0.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "ws": "^8.18.0"
  }
}
