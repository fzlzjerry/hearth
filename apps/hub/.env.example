# ── @hearth/hub (hearthd daemon, runs on your VPS) ──────────────────────────
# Copy to .env (gitignored).

# Bind address + port. Cloudflare Tunnel connects to this locally; keep it on loopback
# in production (the tunnel reaches it; nothing else should).
HOST=127.0.0.1
PORT=8080

# Static service token REST clients (the Next.js app) must present as `Authorization: Bearer ...`.
# MUST equal the web app's HEARTH_TOKEN.  openssl rand -hex 32
HEARTH_TOKEN=change-me-to-a-32-byte-hex-string

# HMAC secret used to verify the short-TTL WS JWTs minted by the web app.
# MUST equal the web app's JWT_SECRET.  openssl rand -hex 32
JWT_SECRET=change-me-to-a-32-byte-hex-string

# Path to the server inventory (credentials live only here).
SERVERS_FILE=./servers.json

# Server-initiated WS ping interval (ms). Keeps idle terminals alive past Cloudflare's ~100s drop.
WS_PING_MS=30000

# Comma-separated Origin allowlist for WS upgrades (CSWSH defense). Set to your Vercel domain(s).
# Leave empty to allow any origin (fine for local dev).
ALLOWED_ORIGIN=https://hearth.example.com

# Log level: fatal|error|warn|info|debug|trace|silent
LOG_LEVEL=info
