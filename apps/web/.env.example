# ── @hearth/web (Next.js, deployed to Vercel) ───────────────────────────────
# Copy to .env.local for local dev, or set these in the Vercel project settings.
# NOTE: none of these are NEXT_PUBLIC_ — they stay server-side. The browser never
# sees HEARTH_TOKEN or JWT_SECRET.

# Where hearthd serves REST (through Cloudflare Tunnel in prod, http://localhost:8080 in dev).
HEARTH_HTTP_URL=https://hearth.example.com

# Where the browser opens the direct terminal WebSocket (wss in prod, ws://localhost:8080 in dev).
HEARTH_WS_URL=wss://hearth.example.com

# Static service token the Next server sends to hearthd on REST calls. MUST match the hub's
# HEARTH_TOKEN. Generate with:  openssl rand -hex 32
HEARTH_TOKEN=change-me-to-a-32-byte-hex-string

# HMAC secret for signing session + WS JWTs. MUST match the hub's JWT_SECRET. Generate with:
#   openssl rand -hex 32
JWT_SECRET=change-me-to-a-32-byte-hex-string

# The single dashboard password. Choose something strong.
DASHBOARD_PASSWORD=change-me
